{
  "name": "ai-chat",
  "version": "1.0.4",
  "description": "Natural-language shell command generation with safe execution for Unix-like terminals.",
  "type": "module",
  "license": "MIT",
  "author": "Ottili ONE",
  "homepage": "https://github.com/Ottili-ONE/ai-cmd",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ottili-ONE/ai-cmd.git"
  },
  "bugs": {
    "url": "https://github.com/Ottili-ONE/ai-cmd/issues"
  },
  "keywords": [
    "cli",
    "shell",
    "terminal",
    "ai",
    "commands",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ai": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "node ./scripts/run-vitest.mjs",
    "test:watch": "vitest",
    "publish:variants": "node ./scripts/publish-variants.mjs"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "jsonrepair": "^3.13.0",
    "prompts": "^2.4.2",
    "shell-quote": "^1.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.13",
    "@types/prompts": "^2.4.9",
    "@types/shell-quote": "^1.7.5",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.9"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Ottili-ONE"
  }
}
